@cli.command(help="This command measures the serial output speed and datarate")
# cli select com port | --com_port yourComPort
@click.option('--com_port', type=str, default="/dev/ttyACM1", help="COM-Port as String - default: /dev/ttyACM0")
# cli select baud rate of serial connection | --baud baud_rate
@click.option('--baud', type=int, default=115200, help="Select Baud rate - default: 112500")
@click.option('--debug', type=bool, default=False, help="Prints the serial Output when Flag is True")

#++++++++++++++++++++++++++++++CLICK FUNCTION filtering++++++++++++++++++++++++++++++#
def serial_meas(com_port, baud, debug):
    import serial

    serialPort = serial.Serial(port = com_port, baudrate=baud, timeout=1)
    c = 0 
    s = time.time()
    n_samples = 10000
    nbr_bytes_usb = 512
    nbr_bytes_sample = 16
    while(c < n_samples):
        rawSerialString = serialPort.read(nbr_bytes_usb)
        if debug: print(rawSerialString)
        c += 1
    samples_per_sec = int(n_samples * (nbr_bytes_usb / nbr_bytes_sample) / (time.time() - s))
    logger.debug(f"Average Samplerate: {samples_per_sec} Samples/sec")
    byte_per_sec = samples_per_sec * nbr_bytes_sample
    logger.debug(f"Datarate (Bytes): {byte_per_sec} Bytes/sec =>> {byte_per_sec / 1e3} kBytes/sec")
    bit_per_sec = byte_per_sec * 8
    logger.debug(f"Datarate (Bit): {bit_per_sec} Bit/sec =>> {bit_per_sec / 1e6} MBit/sec") 



