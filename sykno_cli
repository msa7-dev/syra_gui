# Click Command Name: build_cython
# ==============================================================================
@cli.command(help="This command builds the Cython modules for your Python3 version and CPU architecture")
def build_cython():
    """
    Builds the Cython modules for the specified Python version and CPU architecture.

    This command invokes the setup.py script to compile the Cython modules.

    Example:
    python3 ./radar_eval/proc/cython/setup.py build_ext --inplace
    """
    logger.debug("Building Cython modules...")
    subprocess.run(['python3', './radar_eval/processing/cython/setup.py', 'build_ext', '--inplace'])
    subprocess.run(['python3', './radar_eval/communication/cython/setup.py', 'build_ext', '--inplace'])

    logger.debug("Successfully build cython modules.")


