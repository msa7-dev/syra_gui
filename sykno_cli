@cli.command(help="This command builds a docker image from the Dockerfile")
def build_docker():
    logger.debug("Building docker image from Dockerfile...")
    command = ['sudo', 
               'docker', 'build',
               '--platform', 'linux/arm64',
               '-f', './docker/sykno_gui_dockerfile', 
               '-t', 'sykno_docker', '.'
               ]
    subprocess.run(command)
    logger.debug('Finished docker build.\n Now you can run the docker image with: python3 sykno_cli run-docker')

# ==============================================================================
# Click Command Name: run_docker
# ==============================================================================
@cli.command(help="This command runs the build docker image using QEMU for ARM emulation")
def run_docker():
    logger.debug('Run sykno docker with QEMU...')
    
    # Define the Docker run command with all the arguments
    docker_command = [
        'sudo',  # Run the command with superuser privileges
        'docker',  # Docker CLI command
        'run',  # Run a container from an image
        '-it',  # '-i' keeps STDIN open, '-t' allocates a pseudo-TTY
        '--rm',  # Automatically remove the container when it exits
        '--privileged',  # Give the container elevated privileges
        '--platform', 'linux/arm64',  # Specify target platform (ARM64)
        # '-e', f'DISPLAY={os.getenv("DISPLAY")}',  # Set DISPLAY environment variable for GUI apps
        '-v', '/dev/bus/usb:/dev/bus/usb',  # Mount USB devices directory from host to container
        # '-v', '/tmp/.X11-unix:/tmp/.X11-unix',  # Mount X11 socket for GUI applications
        '-v', f'{os.getcwd()}/mira/meas/hdf5/:/home/sykno/mira/meas/hdf5/',  # Mount host directory to container
        '--hostname', 'sykno-docker',  # Set hostname of the container
        'sykno_docker'  # Docker image name
    ]
    
    result = subprocess.run(docker_command, capture_output=True, text=True)
    
    if result.returncode != 0:
        logger.error(f"Failed to run docker container: {result.stderr}")
    else:
        logger.debug('Closed sykno docker.')


# ==============================================================================
# Click Command Name: flash_mcu
# ==============================================================================
@cli.command(help="This command starts the flashing process for the MCU.")
def flash_mcu():
    from radar_eval.radar_system.radar_system_definition import MIRA_RADAR_PARAMETER
    from radar_eval.radar_sensor.MiRa6024_sensor_device import MIRA_DEVICE
    radar_param = MIRA_RADAR_PARAMETER()
    device = MIRA_DEVICE(radar_param)
    if device.mira_bridge.device is not None:
        logger.debug('Start updating MCU firmware...')
        device.mira_bridge.spi_activate_boot_mode()
        logger.debug('Finished updating MCU firmware.')
    else:
        logger.warning('No device found, please ensure you connected the device.')

