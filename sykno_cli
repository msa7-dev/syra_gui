@cli.command(help="This command starts the Radar GUI application")
def radar_gui():
    """
    Starts the Radar GUI application.

    This command spawns a new process to run the Radar GUI, allowing the main process to continue executing other tasks.

    Example:
    ./sykno_cli radar-gui
    """
    check_setup_venv()
    checker_venv = check_activ_venv()

    if checker_venv:
        # install_requirements()
        start_gui_process()
    else:
        start_mira_venv()


