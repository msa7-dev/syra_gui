@cli.command(help="This command starts the MiRa GUI application")
def mira_gui():
    """
    Starts the MiRa GUI application.

    This command spawns a new process to run the MiRa GUI, allowing the main process to continue executing other tasks.

    Example:
    ./sykno_cli mira-gui
    """
    check_setup_venv()
    checker_venv = check_activ_venv()

    if checker_venv:
        # install_requirements()
        start_mira_process()
    else:
        start_mira_venv()


