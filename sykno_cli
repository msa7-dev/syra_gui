# Click Command Name: compile_gui
# ==============================================================================
@cli.command(help="This command starts the flashing process for the MCU.")
def compile_gui():
    # Compile with Nuitka
    subprocess.run([
        'nuitka3', '--standalone', '--onefile',
        '--enable-plugin=pyqt5',
        '--output-dir=./sykno_radar_eval_project/',
        '--remove-output',
        # '--assume-yes-for-downloads',
        '--python-flag=-OO',  # Remove docstrings and assert statements
        '--lto=yes',  # Enable link-time optimization
        '--follow-imports',
        '--include-package-data=h5py',  # Ensure h5py package data is included
        # '--verbose',  # Enable verbose logging
        '--jobs=20',  # Use multiple jobs for faster compilation
        './radar_gui_starter.py'
    ])

    
# Call the CLI as main to start Click access
