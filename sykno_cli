#+++++++++++++++++++++++++++++++++CLICK FUNCTION plot_xRad+++++++++++++++++++++++++++++++++#

# Interact with the plot_samples_xRad.py script which collects and process the serial xRad data
def plot_xRad(output_mode, com_port, baud, rt_samples, duration_time, n_samples, usb_port, debug):
    import xRad.xRad_rx_convert_Sykno as xRad_rx_convert_Sykno
    if debug: logger.debug(f"xRad CLI called plot function - Processing Started")
    if debug: logger.debug(f"Parameters:\nOutputmode: {output_mode}\n COM-Port: {com_port}\nBaud Rate: {baud}\nDebug Mode: {debug}")
    # Real Time Mode » here a number of RealTimeSamples will be collected befor the plot is updated, the time is terminated by the duration time
    if output_mode == "rt":
        if debug: logger.debug(f"Real Time Samples befor updating plot: {rt_samples}\nMaximum Duration Time in minutes: {duration_time}")
        if usb_port: 
            logger.debug(f"USB-Hub port 1: Power On")
            usb_hub.control_event('/dev/ttyACM0', baud, "port_1_on", debug)
            time.sleep(1)
            logger.debug(f"Plotting Serial Data in Real Time\n")
            xRad_rx_convert_Sykno.plot_real_time(com_port, rt_samples, duration_time, baud, debug)
            usb_hub.control_event('/dev/ttyACM0', baud, "port_1_off", debug)
            logger.debug(f"USB-Hub port 1: Power Off")
        else:
            logger.debug(f"Live Serial Data Plot with {rt_samples} samples per update \n")
            xRad_rx_convert_Sykno.plot_real_time(com_port, rt_samples, duration_time, baud, debug)

    # No Real Time Mode » here a number of samples will be collected befor the data is plotted
    if output_mode == "no_rt":
        if debug: logger.debug(f"Total Number of Samples the will be colleted: {n_samples}")
        if usb_port:
            logger.debug(f"USB-Hub Port 1: Power On")
            usb_hub.control_event('/dev/ttyACM0', baud, "port_1_on", debug)
            time.sleep(1)
            logger.debug(f"Plotting Serial Data with n Samples\n")
            xRad_rx_convert_Sykno.plot_n_samples(com_port, n_samples, baud, debug)
            usb_hub.control_event('/dev/ttyACM0', baud, "port_1_off", debug)
            logger.debug(f"USB-Hub Port 1: Power Off")
        else: 
            if debug: logger.debug(f"Plotting Serial Data with n Samples\n")
            xRad_rx_convert_Sykno.plot_n_samples(com_port, n_samples, baud, debug)



