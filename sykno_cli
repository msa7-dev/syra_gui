# ==============================================================================
@cli.command(help="This command starts the flashing process for the MCU.")
def compile_gui():
    # Command to activate the virtual environment and run the Nuitka compilation
    command = f"""
    nuitka3 --standalone \
    --onefile \
    --enable-plugin=pyqt5 \
    --output-dir=./sykno_radar_eval_project/ \
    --remove-output \
    --show-modules \
    --python-flag=-OO \
    --lto=yes \
    --follow-imports \
    --include-package-data=h5py \
    --include-module=usb \
    --include-module=h5py \
    --include-module=PyQt5 \
    --include-module=scipy \
    --include-package-data=scipy \
    --include-module=scipy.special \
    --include-module=scipy.special._ufuncs \
    --include-module=scipy.special._ufuncs_cxx \
    --include-module=scipy.special._cdflib \
    --jobs=20 \
    ./radar_gui_starter.py
    """

    # Run the command in a shell
    subprocess.run(command, shell=True, executable='/bin/bash')

    
