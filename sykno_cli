@cli.command(help="This command builds a docker image from the Dockerfile")
def build_docker():
    logger.debug("Building docker image from Dockerfile...")
    subprocess.run(['sudo', 'docker', 'build', '-f', './docker/sykno_gui_dockerfile', '-t', 'sykno_docker', '.'])
    logger.debug('Finished docker build.\n Now you can run the docker image with: python3 sykno_cli run-docker')


# ==============================================================================
# Click Command Name: run_docker
# ==============================================================================
@cli.command(help="This command runs the build docker image")
def run_docker():
    logger.debug('Run sykno docker...')
    subprocess.run(['sudo', 'docker', 'run', '-it', '--rm', '--privileged', 
                    '-e', 'DISPLAY=$DISPLAY', '-v', '/dev/bus/usb:/dev/bus/usb', \
                    '-v', '/tmp/.X11-unix:/tmp/.X11-unix',
                    '-v', './radar_eval/measurement/hdf5/:/home/sykno/radar_eval/measurement/hdf5/',
                    '--hostname', 'sykno-docker', 'sykno_docker'])
    logger.debug('Closed sykno docker.')

# ==============================================================================
# Click Command Name: flash_mcu
# ==============================================================================
@cli.command(help="This command starts the flashing process for the MCU.")
def flash_mcu():
    from radar_eval.radar_system.radar_system_definition import MIRA_RADAR_PARAMETER
    from radar_eval.radar_sensor.MiRa6024_sensor_device import MIRA_DEVICE
    radar_param = MIRA_RADAR_PARAMETER()
    device = MIRA_DEVICE(radar_param)
    if device.mira_bridge.device is not None:
        logger.debug('Start updating MCU firmware...')
        device.mira_bridge.spi_activate_boot_mode()
        logger.debug('Finished updating MCU firmware.')
    else:
        logger.warning('No device found, please ensure you connected the device.')


