# Use an official Ubuntu as a parent image
FROM ubuntu:latest

# Set the working directory in the container
WORKDIR /home/sykno/

# Copy the current directory contents into the container at /home/sykno
COPY . .

# Avoid interactive dialogues from apt-get and set the timezone
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# Remove the unavailable package if not critical
RUN apt-get update -y && apt-get upgrade -y && \
    apt-get install -y apt-utils sudo tzdata usbutils udev \
    wget build-essential checkinstall libreadline-dev \
    libncursesw5-dev libssl-dev libsqlite3-dev tk-dev \
    libgdbm-dev libc6-dev libbz2-dev libffi-dev zlib1g-dev \
    tzdata x11-xserver-utils libusb-1.0-0-dev libftdi1-dev \
    libqt5svg5* libglib2.0-0 libsm6 libxrender1 libxext6 && \
    ln -fs /usr/share/zoneinfo/UTC /etc/localtime && \
    dpkg-reconfigure -f noninteractive tzdata && \
    apt-get autoremove -y && apt-get autoclean -y

# Copy the udev rules
RUN cp /home/sykno/radar_eval/setup/unix/udev/99-sykno_usb_device.rules /etc/udev/rules.d/

# Download and install Python 3.11
RUN cd /tmp && \
    wget https://www.python.org/ftp/python/3.11.2/Python-3.11.2.tar.xz && \
    tar -xf Python-3.11.2.tar.xz && \
    cd Python-3.11.2 && \
    ./configure --enable-optimizations && \
    make -j 8 && \
    make altinstall

# Upgrade pip and install Python packages
RUN python3.11 -m pip install --upgrade pip && \
    python3.11 -m pip install -r /home/sykno/radar_eval/setup/requirements.txt

# Define the command to run the application
RUN taskset -c 1 python3.11 -B ./sykno_cli build-cython
RUN taskset -c 1 python3.11 -B ./sykno_cli setup-env
